# Copier vers .env.local et renseigner les valeurs (ne jamais committer de secrets).

# --- Carte & trajets (accueil Palto) ---
VITE_OPENSTREET_ACCESS_TOKEN=

# URL canonique du site (SEO, JSON-LD). Exemple : https://palto.example
# VITE_SITE_URL=

# --- Analytics optionnels (aucun ID hardcodé dans le code) ---
# VITE_GA_MEASUREMENT_ID=G-...
# VITE_GTM_ID=GTM-...
# VITE_RB2B_KEY=
# VITE_ENABLE_VERCEL_ANALYTICS=0
# VITE_ENABLE_SPEED_INSIGHTS=0
# VITE_ANALYTICS_DEBUG=0

# --- Réseaux sociaux (footer Hero / page 404) : optionnel, liens masqués si vides ---
# VITE_SOCIAL_GITHUB_URL=https://github.com/votre-org/votre-repo
# VITE_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/...
# VITE_SOCIAL_FIGMA_URL=https://www.figma.com/@votre-compte

# --- Dashboard (auth locale en dev + fallback si API indispo) ---
# VITE_DASHBOARD_EMAIL=
# VITE_DASHBOARD_PASSWORD=

# --- Dashboard en production (Vercel : sans préfixe VITE_) ---
# DASHBOARD_EMAIL=
# DASHBOARD_PASSWORD=

# --- Base API (front) ---
# VITE_API_BASE_URL=/api

# --- Rollout progressif (feature flags front) ---
# 0/false = fallback legacy, 1/true = source API prioritaire
# VITE_CHAUFFEUR_RIDES_PERSIST=0
# VITE_USE_PRICING_API=0
# VITE_USE_ORG_API=0
# VITE_USE_COMPLIANCE_API=0
# VITE_USE_CLIENT_RIDES_API=0
# VITE_USE_STATS_API=0

# --- Supabase (projet palto : uzjplpdpbxvzhisxgwfz) — guide docs/SUPABASE-CONNEXION.md ---
# SUPABASE_URL=https://uzjplpdpbxvzhisxgwfz.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # secret — Settings → API (jamais VITE_)
# VITE_SUPABASE_URL=https://uzjplpdpbxvzhisxgwfz.supabase.co
# VITE_SUPABASE_ANON_KEY=      # anon ou publishable (publique)
# VITE_API_BASE_URL=/api       # local : avec `npx vercel dev` (pas seulement npm run dev)
# Secret JWT projet (Settings > API > JWT Secret) : pour /api/auth/realtime-token + RLS Realtime
# SUPABASE_JWT_SECRET=

# --- Realtime navigateur (postgres_changes sur courses / course_events) ---
# VITE_SUPABASE_URL=   # même URL projet que SUPABASE_URL
# VITE_SUPABASE_ANON_KEY=   # clé anon (publishable), jamais la service role

# --- Page Go : chauffeurs mock = vrais UUID comptes chauffeur (ordre = d1, d2, … dans l’UI) ---
# Sans cela, les ids restent d1, d2… et une commande instantanée ne cible aucun compte réel.
# Récupérer les UUID dans Supabase (app_accounts, role = chauffeur).
# UUID compte chauffeur (app_accounts role=chauffeur), 1er de la liste = 1er mock sur /go
# Ex. Océane : e09f65c3-f47e-413c-ba41-2ea2749f86ec
# (optionnel, mock local uniquement — non utilisé par la page Go en prod)
# VITE_NEARBY_DRIVER_ACCOUNT_IDS=uuid1,uuid2

# --- Stripe (page Go — autorisation carte, mode test pk_test_ / sk_test_) ---
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...          # Vercel + vercel dev (jamais VITE_)
# STRIPE_WEBHOOK_SECRET=whsec_...        # optionnel (Dashboard ou stripe listen)

# --- Resend (contact + reset mot de passe — voir RESEND_CONTACT.md) ---
# RESEND_API_KEY=
# RESEND_TO_EMAIL=          # obligatoire pour /api/send (contact)
# RESEND_FROM=Palto <noreply@votre-domaine.com>
# APP_BASE_URL=https://palto-six.vercel.app   # liens email (reset mot de passe)

# --- Cron Vercel sécurisé (expiration + rappels email courses) ---
# CRON_SECRET=un-secret-long-et-aleatoire
