# Copier vers .env.local et renseigner les valeurs (ne jamais committer de secrets).

# --- Carte & trajets (accueil Palto) ---
VITE_OPENSTREET_ACCESS_TOKEN=

# URL canonique du site (SEO, JSON-LD). Exemple : https://palto.example
# VITE_SITE_URL=

# --- Réseaux sociaux (footer Hero / page 404) : optionnel, liens masqués si vides ---
# VITE_SOCIAL_GITHUB_URL=https://github.com/votre-org/votre-repo
# VITE_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/...
# VITE_SOCIAL_FIGMA_URL=https://www.figma.com/@votre-compte

# --- Dashboard (auth locale en dev + fallback si API indispo) ---
# VITE_DASHBOARD_EMAIL=
# VITE_DASHBOARD_PASSWORD=

# --- Dashboard en production (Vercel : sans préfixe VITE_) ---
# DASHBOARD_EMAIL=
# DASHBOARD_PASSWORD=

# --- Base API (front) ---
# VITE_API_BASE_URL=/api

# --- Rollout progressif (feature flags front) ---
# 0/false = fallback legacy, 1/true = source API prioritaire
# VITE_CHAUFFEUR_RIDES_PERSIST=0
# VITE_USE_PRICING_API=0
# VITE_USE_ORG_API=0
# VITE_USE_COMPLIANCE_API=0
# VITE_USE_CLIENT_RIDES_API=0
# VITE_USE_STATS_API=0

# --- Commandes courses (Supabase) : POST /api/rides/create depuis la page Go ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Secret JWT projet (Settings > API > JWT Secret) : pour /api/auth/realtime-token + RLS Realtime
# SUPABASE_JWT_SECRET=

# --- Realtime navigateur (postgres_changes sur courses / course_events) ---
# VITE_SUPABASE_URL=   # même URL projet que SUPABASE_URL
# VITE_SUPABASE_ANON_KEY=   # clé anon (publishable), jamais la service role

# --- Contact Resend (voir RESEND_CONTACT.md) ---
# RESEND_API_KEY=
# RESEND_TO_EMAIL=
# RESEND_FROM=Palto <noreply@votre-domaine.com>
